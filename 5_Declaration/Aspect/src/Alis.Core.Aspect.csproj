<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks Condition="'$(Configuration)' == 'Debug'">
            netcoreapp2.0;
            net5.0;net8.0;net10.0;
            netstandard2.0;
            net461;
        </TargetFrameworks>

        <TargetFrameworks Condition="'$(Configuration)' == 'Release'">
            netcoreapp2.0;netcoreapp2.1;netcoreapp2.2;netcoreapp3.0;netcoreapp3.1;
            net5.0;net6.0;net7.0;net8.0;net9.0;net10.0;
            netstandard2.0;netstandard2.1;
            net461;net471;net472;net48;net481;
        </TargetFrameworks>

        

        <Configurations>Debug;Release;Win;Osx;Linux;Browser;Android;Ios</Configurations>
        <Platforms>AnyCPU;x64;x86;arm;arm64;wasm;simulator_x64;simulator_arm64</Platforms>
        
        <OutDir>bin/$(Configuration)/$(RuntimeIdentifier)/lib/$(TargetFramework)/</OutDir>

        <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
        <LangVersion>13</LangVersion>
        <Nullable>disable</Nullable>
        <OutputType>Library</OutputType>
        <NeutralLanguage>en</NeutralLanguage>
        <WarningsAsErrors>true</WarningsAsErrors>
        <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <EnableNETAnalyzers>true</EnableNETAnalyzers>
        <AnalysisMode>AllEnabledByDefault</AnalysisMode>
        <AnalysisMode>AllEnabledByDefault</AnalysisMode>
        <AnalysisLevel>latest</AnalysisLevel>

         <TargetFrameworks Condition="'$(Configuration)' == 'Win'">netcoreapp2.0;net5.0;net8.0;net10.0;netstandard2.0;net461;</TargetFrameworks>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Win' AND '$(Platform)' == 'arm64'">win-arm64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Win' AND '$(Platform)' == 'arm'">win-arm</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Win' AND '$(Platform)' == 'x64'">win-x64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Win' AND '$(Platform)' == 'x86'">win-x86</RuntimeIdentifier>

        <TargetFrameworks Condition="'$(Configuration)' == 'Osx'">net5.0;net8.0;net10.0;netstandard2.0;</TargetFrameworks>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Osx' AND '$(Platform)' == 'arm64'">osx-arm64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Osx' AND '$(Platform)' == 'x64'">osx-x64</RuntimeIdentifier>
        
        <TargetFrameworks Condition="'$(Configuration)' == 'Linux'">net5.0;net8.0;net10.0;netstandard2.0;</TargetFrameworks>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Linux' AND '$(Platform)' == 'arm'">linux-arm</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Linux' AND '$(Platform)' == 'arm64'">linux-arm64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Linux' AND '$(Platform)' == 'x64'">linux-x64</RuntimeIdentifier>

        <TargetFrameworks Condition="'$(Configuration)' == 'Browser'">net8.0;net10.0;netstandard2.0;</TargetFrameworks>
        

        <TargetFrameworks Condition="'$(Configuration)' == 'Ios'">net8.0;net10.0;netstandard2.0;</TargetFrameworks>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Ios' AND '$(Platform)' == 'arm64'">ios-arm64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Ios' AND '$(Platform)' == 'x64'">ios-x64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Ios' AND '$(Platform)' == 'simulator_x64'">iossimulator-x64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Ios' AND '$(Platform)' == 'simulator_arm64'">iossimulator-arm64</RuntimeIdentifier>

        <TargetFrameworks Condition="'$(Configuration)' == 'Android'">net8.0;net10.0;netstandard2.0;</TargetFrameworks>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Android' AND '$(Platform)' == 'arm64'">android-arm64</RuntimeIdentifier>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Android' AND '$(Platform)' == 'x64'">android-x64</RuntimeIdentifier>
    </PropertyGroup>

    <PropertyGroup>
        <DefineConstants Condition="'$(RuntimeIdentifier)' != ''">$(DefineConstants);$([System.String]::Copy('$(RuntimeIdentifier)').Replace('-',''));</DefineConstants>

        <DefineConstants Condition="
                '$(RuntimeIdentifier)' != '' AND 
                ($([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('ubuntu')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('debian')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('alpine')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('centos')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('fedora')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('rocky')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('rhel')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('opensuse')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('raspbian')) == True OR
                 $([System.String]::Copy('$(RuntimeIdentifier)').StartsWith('mariner')) == True)
                ">$(DefineConstants);linux$([System.Text.RegularExpressions.Regex]::Match('$(RuntimeIdentifier)', '(x64|arm64|arm|x86)$').Value)</DefineConstants>

        <DefineConstants Condition="'$(RuntimeIdentifier)' == ''">$([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').Replace('-',''));</DefineConstants>

        <DefineConstants Condition="
                '$(RuntimeIdentifier)' == '' AND 
                ($([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('ubuntu')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('debian')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('alpine')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('centos')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('fedora')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('rocky')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('rhel')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('opensuse')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('raspbian')) == True OR
                 $([System.String]::Copy('$(NETCoreSdkRuntimeIdentifier)').StartsWith('mariner')) == True)
                ">$(DefineConstants);linux$([System.Text.RegularExpressions.Regex]::Match('$(NETCoreSdkRuntimeIdentifier)', '(x64|arm64|arm|x86)$').Value)</DefineConstants>

    </PropertyGroup>

    <PropertyGroup>
        <NoWarn>$(NoWarn);CS1685;NU1900</NoWarn> <!-- Error CS1685 : Warning As Error: Define on differente assemblys of alias gloabal -->
        <NoWarn>$(NoWarn);CS0436;RS2007</NoWarn> <!-- Error CS0436 : Warning As Error: Overriding dependency version -->
        <NoWarn>$(NoWarn);NU1903</NoWarn> <!-- Error NU1903 : Warning As Error: Package has high severity vulnerability -->
        <NoWarn>$(NoWarn);NU1902</NoWarn> <!-- Error NU1902 : Warning As Error: Package has moderate severity vulnerabilities -->
        <NoWarn>$(NoWarn);CS0162</NoWarn>
        <NoWarn>$(NoWarn);NU5128</NoWarn> <!-- Error NU5128 : Warning As Error: The package contains a project reference -->
        <NoWarn>$(NoWarn);CS0067;CA1054;NU1904;MSB3245;CS1685;CA1815;CA2225;CA1051;CA2000;CA1062;CA1065;CA5392;CA1838;CA5392;A1834;CA2208;CA1725;CA1825;CA1044;CA2201;CA1024;CA1000;CA1813;CA1018;CA1032;CA1716;CA1040;CA1308;CA1721;CA1066;CA1866;CA1305;CA1310;CA1031;CA1034;CA1711;CA2249;CA1863;CA2007;CA1309;CA1822;CA1823;CA1824;CA1825;CA1826;CA1827;CA1828;CA1829;CA1830;CA1831;CA1832;CA1833;CA1834;CA1835;CA1836;CA1837;CA1838;CA1839;CA1840;CA1841;CA1842;CA1843;CA1844;CA1845;CA1846;CA1847;CA1848;CA1849;CA1850;CA1851;CA1852;CA1853;CA1854;CA1855;CA1856;CA1857;CA1858;CA1859;CA1860;CA1861;CA1862;CA1863;CA1864;CA1865;CA1866;CA1867;CA1868;CA1869;CA1870;CA1871;CA1872;CA1873;CA1874;CA1875;CA1876;CA1877;CA1878;CA1879;CA1880;CA1881;CA1882;CA1883;CA1884;CA1885;CA1886;CA1311;CA1304;CA1303;CA1307;CA2101;CA1806;CA1819;CA1008;CA1720;CA1805;CA1069;CA1028;CA1707;CA2227;CA1002;CA1003;CA2211;CA1012;CA1814;CA1063;CA1802;CA1507;CA1510;CA1030;CA1508;CA1033;CA1019;CA1052;CA2231;CA1810;CA1401;CA1512;CA1820;CA1708;CA2019;CA1710;CA2263;CA1724;CA2213;CA5398;CA2016;CA2213;CA5398;CA1712;CA1027;CA1700;CA2217;CA2237;CS1591;CA2020;ALIS009;ALIS010;ALIS001;NU1904;SYSLIB1054</NoWarn>
        <NoWarn>$(NoWarn);S4136</NoWarn> <!-- Warning S4136 : Method overloads should be grouped together -->
        <NoWarn>$(NoWarn);S4200</NoWarn> <!-- Warning S4200 : Native methods should be wrapped -->
        <NoWarn>$(NoWarn);S3925</NoWarn>  <!-- "ISerializable" should be implemented correctly -->
        <NoWarn>$(NoWarn);S3267</NoWarn> <!-- Warning S3267 : Loops should be simplified with "LINQ" expressions -->
        <NoWarn>$(NoWarn);CA1816;CA1816;CS0419;CS1572;CS1573;CS1574;CS1734;CS1572;CS1573;CS1574;CS0419;CS1734</NoWarn>
    </PropertyGroup>

     <ItemGroup>
        <None Remove="$(ProjectDir)runtimes/**"/>
    </ItemGroup>

    <ItemGroup Condition="'$(RuntimeIdentifier)' == ''">
        <None Include="runtimes/**" Pack="true" PackagePath="runtimes/" Visible="true" CopyToOutputDirectory="Never" CopyToPublishDirectory="Never"/>
    </ItemGroup>

    <ItemGroup Condition="'$(RuntimeIdentifier)' != '' AND Exists('$(ProjectDir)runtimes/$(RuntimeIdentifier)/native/')">
        <None Include="runtimes/$(RuntimeIdentifier)/native/**" Link="%(Filename)%(Extension)" Pack="false" Visible="true" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest"/>
    </ItemGroup>

    <ItemGroup Condition="$(NETCoreSdkRuntimeIdentifier) != '' AND '$(RuntimeIdentifier)' == '' AND Exists('$(ProjectDir)runtimes/$(NETCoreSdkRuntimeIdentifier)/native/')">
        <None Include="runtimes/$(NETCoreSdkRuntimeIdentifier)/native/**" Link="%(Filename)%(Extension)" Visible="true" Pack="false" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="$(SolutionDir)license.md" LinkBase=".docs/" Pack="true" Visible="true" PackagePath="."/>
        <None Include="$(SolutionDir)/readme.md" LinkBase=".docs/" Pack="true" Visible="true" PackagePath="."/>
        <None Include="$(SolutionDir)docs/logo/logo.png" LinkBase=".docs/" Pack="true" Visible="true" PackagePath="."/>
        <None Condition="Exists('$(ProjectDir).docs/')" Include="$(ProjectDir).docs/**/*.md" Pack="false" Visible="true"/>
    </ItemGroup>
    
    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All"/>
        <InternalsVisibleTo Include="$(AssemblyName).Test"/>
    </ItemGroup>

    <ItemGroup Condition="
    $(TargetFramework.Equals('net461')) OR
    $(TargetFramework.Equals('net462')) OR 
    $(TargetFramework.Equals('net463')) OR 
    $(TargetFramework.Equals('net47'))  OR 
    $(TargetFramework.Equals('net471')) OR 
    $(TargetFramework.Equals('net472')) OR 
    $(TargetFramework.Equals('net48'))  OR 
    $(TargetFramework.Equals('net481'))
    ">
        <PackageReference Include="System.IO.Compression" Version="4.3.0"/>
        <PackageReference Include="System.Net.Http" Version="4.3.0"/>
        <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.1.1"/>
        <PackageReference Include="System.Memory" Version="4.6.2"/>
    </ItemGroup>

    <ItemGroup Condition="
    $(TargetFramework.Equals('netcoreapp2.0')) OR
    $(TargetFramework.Equals('netcoreapp2.1')) OR
    $(TargetFramework.Equals('netcoreapp2.2')) OR
    $(TargetFramework.Equals('netcoreapp3.0')) OR
    $(TargetFramework.Equals('netcoreapp3.1')) 
    ">
        <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.1.1"/>
        <PackageReference Include="System.Memory" Version="4.6.2"/>
    </ItemGroup>

    <ItemGroup Condition="
    $(TargetFramework.Equals('netstandard2.0')) OR
    $(TargetFramework.Equals('netstandard2.1'))
    ">
        <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.1.1"/>
        <PackageReference Include="System.Memory" Version="4.6.2"/>
    </ItemGroup>
    
    <PropertyGroup>
        <FileVersion>$(AssemblyVersion)</FileVersion>
        <Company>Pablo Perdomo Falcón</Company>
        <Product>Alis</Product>
        <Authors>$(Company)</Authors>
        <Copyright>GNU General Public License v3.0</Copyright>
        <Description>Videogame cross-platform framework for Windows, MacOS, Linux, WEB, Android(soon), IOS(soon).</Description>
        <FileVersion>$(AssemblyVersion)</FileVersion>
        <InformationalVersion>$(AssemblyInformationalVersion)</InformationalVersion>
        <IsPackable>true</IsPackable>
        <PackageIcon>logo.png</PackageIcon>
        <PackageLicenseFile>license.md</PackageLicenseFile>
        <PackageProjectUrl>www.alisengine.com</PackageProjectUrl>
        <PackageReadmeFile>readme.md</PackageReadmeFile>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <PackageTags>game framework windows macos linux ios android web</PackageTags>
        <PackageVersion>$(AssemblyVersion)</PackageVersion>
        <RepositoryType>public</RepositoryType>
        <RepositoryUrl>https://github.com/pabllopf/Alis</RepositoryUrl>
        <Title>$(AssemblyName)</Title>
        <Version>$(AssemblyVersion)</Version>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="$(SolutionDir)6_Ideation/Data/src/Alis.Core.Aspect.Data.csproj" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Fluent/src/Alis.Core.Aspect.Fluent.csproj" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Logging/src/Alis.Core.Aspect.Logging.csproj" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Math/src/Alis.Core.Aspect.Math.csproj" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Memory/src/Alis.Core.Aspect.Memory.csproj" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Time/src/Alis.Core.Aspect.Time.csproj" />
        
        <ProjectReference Include="$(SolutionDir)6_Ideation/Data/generator/Alis.Core.Aspect.Data.Generator.csproj"  OutputItemType="Analyzer" PrivateAssets="all" ReferenceOutputAssembly="false" Properties="TargetFramework=netstandard2.0;RuntimeIdentifier=''" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Fluent/generator/Alis.Core.Aspect.Fluent.Generator.csproj" OutputItemType="Analyzer" PrivateAssets="all" ReferenceOutputAssembly="false" Properties="TargetFramework=netstandard2.0;RuntimeIdentifier=''" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Memory/generator/Alis.Core.Aspect.Memory.Generator.csproj" OutputItemType="Analyzer" PrivateAssets="all" ReferenceOutputAssembly="false" Properties="TargetFramework=netstandard2.0;RuntimeIdentifier=''" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Logging/generator/Alis.Core.Aspect.Logging.Generator.csproj" OutputItemType="Analyzer" PrivateAssets="all" ReferenceOutputAssembly="false" Properties="TargetFramework=netstandard2.0;RuntimeIdentifier=''" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Math/generator/Alis.Core.Aspect.Math.Generator.csproj" OutputItemType="Analyzer" PrivateAssets="all" ReferenceOutputAssembly="false" Properties="TargetFramework=netstandard2.0;RuntimeIdentifier=''" />
        <ProjectReference Include="$(SolutionDir)6_Ideation/Time/generator/Alis.Core.Aspect.Time.Generator.csproj" OutputItemType="Analyzer" PrivateAssets="all" ReferenceOutputAssembly="false" Properties="TargetFramework=netstandard2.0;RuntimeIdentifier=''" />
    </ItemGroup>

</Project>