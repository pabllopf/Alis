{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "senior-engineer",
  "share": "auto",
  "permission": "allow",

  "model": "omlx/Qwen3.5-35B-A3B-4bit",

  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "1234"
      },
      "models": {
        "Qwen3.5-35B-A3B-4bit": {
          "name": "Qwen3.5-35B-A3B-4bit",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "attachment": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "Qwen2.5-Coder-7B-4bit": {
          "name": "Qwen2.5-Coder-7B-4bit",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "attachment": false,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "strategy": "aggressive"
  },

  "watcher": {
    "ignore": [
      ".vs/", ".vscode/", ".idea/", ".test/", ".temp/", ".publish/", ".nuget/",
      ".venv/", "Release/", "Debug/",
      "**/bin/**", "**/obj/**", "**/build/**",
      "**/.DS_Store", "*.log", "*.tmp", "*.pdb", "*.exe"
    ]
  },

  "instructions": [
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md"
  ],

  "tools": {
    "ripgrep": true,
    "fd": true,
    "write": true,
    "edit": true,
    "bash": true
  },

  "plugin": [
    ".opencode/plugins/tree-sitter-csharp.js",
    ".opencode/plugins/test-impact.js",
    ".opencode/plugins/git-smart-context.js",
    ".opencode/plugins/file-summary-cache.js"
  ],

  "autoupdate": false,

  "agent": {
    "senior-engineer": {
      "model": "omlx/Qwen3.5-35B-A3B-4bit",
      "prompt": "Use this agent for architecture, reasoning, design decisions, debugging and non-trivial implementation.",
      "tools": { "write": true, "edit": true, "bash": true }
    },

    "worker": {
      "model": "omlx/Qwen2.5-Coder-7B-4bit",
      "prompt": "Use this agent for simple code generation, CLI commands, boilerplate, refactors, and small isolated tasks.",
      "tools": { "write": true, "edit": true, "bash": true }
    }
  }
}