{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "senior-engineer",
  "share": "auto",
  "permission": "allow",

  "model": "omlx/NVIDIA-Nemotron-3-Nano-30B-A3B-MLX-MXFP4",

  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "1234"
      },
      "models": {
        "NVIDIA-Nemotron-3-Nano-30B-A3B-MLX-MXFP4": {
          "name": "NVIDIA-Nemotron-3-Nano-30B-A3B-MLX-MXFP4",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "attachment": true,
          "limit": {
            "context": 65792,
            "output": 16384
          }
        }
      }
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "strategy": "aggressive"
  },

  "watcher": {
    "ignore": [
      ".vs/", ".vscode/", ".idea/", ".test/", ".temp/", ".publish/", ".nuget/",
      ".venv/", "Release/", "Debug/",
      "**/bin/**", "**/obj/**", "**/build/**",
      "**/.DS_Store", "*.log", "*.tmp", "*.pdb", "*.exe"
    ]
  },

  "instructions": [
    "CONTRIBUTING.md"
  ],

  "tools": {
    "ripgrep": true,
    "fd": true,
    "write": true,
    "edit": true,
    "bash": true
  },

  "plugin": [
    ".opencode/plugins/tree-sitter-csharp.js",
    ".opencode/plugins/test-impact.js",
    ".opencode/plugins/git-smart-context.js",
    ".opencode/plugins/file-summary-cache.js"
  ],

  "autoupdate": false,

  "agent": {
    "senior-engineer": {
      "path": ".opencode/agents/senior-engineer.md"
    }
  }
}