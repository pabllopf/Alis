{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "build",
  "share": "auto",
  "permission": "allow",

  "model": "omlx/Qwen3.5-35B-A3B-4bit",

  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "1234"
      },
      "models": {
        "Qwen3.5-35B-A3B-4bit": {
          "name": "Qwen3.5-35B-A3B-4bit",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "attachment": false
        }
      }
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "strategy": "aggressive"
  },

  "watcher": {
    "ignore": [
      ".vs/", ".vscode/", ".idea/", ".test/", ".temp/", ".publish/", ".nuget/",
      ".venv/", "Release/", "Debug/",
      "**/bin/**", "**/obj/**", "**/build/**",
      "**/.DS_Store", "*.log", "*.tmp", "*.pdb", "*.exe"
    ]
  },

  "instructions": [
    "CONTRIBUTING.md"
  ],

  "tools": {
    "ripgrep": true,
    "fd": true,
    "write": true,
    "edit": true,
    "bash": true
  },

  "plugin": [
    ".opencode/plugins/tree-sitter-csharp.js",
    ".opencode/plugins/test-impact.js",
    ".opencode/plugins/git-smart-context.js",
    ".opencode/plugins/file-summary-cache.js"
  ],

  "autoupdate": false
}