{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "senior-engineer",
  "share": "auto",
  "permission": "allow",

  "model": "omlx/Qwen3.5-35B-A3B-4bit",

  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "1234"
      },
      "models": {
        "Qwen3.5-35B-A3B-4bit": {
          "name": "Qwen3.5-35B-A3B-4bit",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "attachment": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },

        "Qwen3.6-35B-A3B-UD-MLX-4bit": {
          "name": "Qwen3.6-35B-A3B-UD-MLX-4bit",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "attachment": true,
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },

        "Qwen2.5-Coder-3B-4bit": {
          "name": "Qwen2.5-Coder-3B-4bit",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "attachment": false,
          "limit": {
            "context": 16384,
            "output": 2048
          }
        },

        "Qwen2.5-Coder-1.5B-4bit": {
          "name": "Qwen2.5-Coder-1.5B-4bit",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "attachment": false,
          "limit": {
            "context": 8192,
            "output": 1024
          }
        }
      }
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "strategy": "aggressive"
  },

  "watcher": {
    "ignore": [
      ".vs/", ".vscode/", ".idea/", ".test/", ".temp/", ".publish/", ".nuget/",
      ".venv/", "Release/", "Debug/",
      "**/bin/**", "**/obj/**", "**/build/**",
      "**/.DS_Store", "*.log", "*.tmp", "*.pdb", "*.exe"
    ]
  },

  "instructions": [
    "CONTRIBUTING.md"
  ],

  "tools": {
    "ripgrep": true,
    "fd": true,
    "write": true,
    "edit": true,
    "bash": true
  },

  "plugin": [
    ".opencode/plugins/tree-sitter-csharp.js",
    ".opencode/plugins/test-impact.js",
    ".opencode/plugins/git-smart-context.js",
    ".opencode/plugins/file-summary-cache.js"
  ],

  "autoupdate": false,

  "agent": {
    "senior-engineer": {
      "path": ".opencode/agents/senior-engineer.md"
    },

    "explorer": {
      "path": ".opencode/agents/explorer.md"
    },

    "dotnet-architect": {
      "path": ".opencode/agents/dotnet-architect.md"
    },

    "performance-engineer": {
      "path": ".opencode/agents/performance-engineer.md"
    },

    "test-engineer": {
      "path": ".opencode/agents/test-engineer.md"
    },

    "reviewer": {
      "path": ".opencode/agents/reviewer.md"
    },

    "rendering-specialist": {
      "path": ".opencode/agents/rendering-specialist.md"
    },

    "build-coordinator": {
      "path": ".opencode/agents/build-coordinator.md"
    }
  }
}