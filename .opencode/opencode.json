{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "share": "auto",
  "permission": "allow",

  "model": "omlx/Qwen3.6-35B-A3B-UD-MLX-4bit",

 "provider": {
  "omlx": {
    "npm": "@ai-sdk/openai-compatible",
    "name": "oMLX",
    "options": {
      "baseURL": "http://127.0.0.1:8000/v1",
      "apiKey": "1234"
    },
    "models": {
      "Qwen3.6-35B-A3B-UD-MLX-4bit": {
        "name": "Qwen3.6-35B-A3B-UD-MLX-4bit",
        "modalities": {
          "input": ["text", "image"],
          "output": ["text"]
        },
        "attachment": true,
        "limit": {
          "context": 131072,
          "output": 8192
        }
      },

      "Devstral-Small-2-24B-Instruct-2512-4bit": {
        "name": "Devstral-Small-2-24B-Instruct-2512-4bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 32768,
          "output": 8192
        }
      },

      "Llama-3.1-8B-Instruct-4bit": {
        "name": "Llama-3.1-8B-Instruct-4bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 131072,
          "output": 8192
        }
      },

      "Meta-Llama-3-8B-Instruct-4bit": {
        "name": "Meta-Llama-3-8B-Instruct-4bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 8192,
          "output": 4096
        }
      },

      "Qwen2.5-Coder-7B-Instruct-MLX-4bit": {
        "name": "Qwen2.5-Coder-7B-Instruct-MLX-4bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 32768,
          "output": 8192
        }
      },

      "Qwen3-Coder-30B-A3B-Instruct-MLX-4bit": {
        "name": "Qwen3-Coder-30B-A3B-Instruct-MLX-4bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 131072,
          "output": 8192
        }
      },

      "Qwen3-Coder-Next-8bit": {
        "name": "Qwen3-Coder-Next-8bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 262144,
          "output": 16384
        }
      },

      "Qwen3.6-35B-A3B-nvfp4": {
        "name": "Qwen3.6-35B-A3B-nvfp4",
        "modalities": {
          "input": ["text", "image"],
          "output": ["text"]
        },
        "attachment": true,
        "limit": {
          "context": 131072,
          "output": 8192
        }
      },

      "gemma-4-e2b-it-4bit": {
        "name": "gemma-4-e2b-it-4bit",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 32768,
          "output": 8192
        }
      },

      "gpt-oss-20b-MXFP4-Q8": {
        "name": "gpt-oss-20b-MXFP4-Q8",
        "modalities": {
          "input": ["text"],
          "output": ["text"]
        },
        "attachment": false,
        "limit": {
          "context": 131072,
          "output": 8192
        }
      }
    }
  }
},

  "compaction": {
    "auto": true,
    "prune": true,
    "strategy": "aggressive"
  },

  "watcher": {
    "ignore": [
      ".vs/",
      ".vscode/",
      ".idea/",
      ".test/",
      ".temp/",
      ".publish/",
      ".nuget/",
      ".venv/",
      "Release/",
      "Debug/",

      "**/.vs/**",
      "**/.vscode/**",
      "**/.idea/**",
      "**/.test/**",
      "**/.temp/**",
      "**/.publish/**",
      "**/.nuget/**",

      "**/bin/**",
      "**/obj/**",
      "**/lib/**",

      "**/vs/**",
      "**/vscode/**",
      "**/idea/**",

      "**/graphify-out/**",
      "**/test/**",

      "**/_/**",
      "**/build/**",
      "**/.build/**",

      "**/.DS_Store",
      "**/.log",

      "**/.xsd",

      "*.log",
      "*.html",
      "*.css",
      "*.js",
      "*.c",
      "*.exe",
      "*.template.json",
      "*.nupkg",
      "*.suo",
      "*.user",
      "*.userprefs",
      "*.pidb",
      "*.booproj",
      "*.svd",
      "*.pdb",
      "*.deb",
      "*.gitattributes",
      "*.nojekyll",
      "*.tar",
      "*.mdb",
      "*.opendb",
      "*.collabignore",
      "*.tmp",
      "*.TMP",
      "*.htm",
      "*.txt",

      "*StyleCop.Cache",
      "*alis.sln.DotSettings.user",
      "*DS_Store",
      "*FodyWeavers.xml",
      "*FodyWeavers.xsd",

      ".sonarqube/"
    ]
  },

  "instructions": [
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md"
  ],

  "tools": {
    "ripgrep": true,
    "fd": true,
    "write": true,
    "bash": true
  },

  "plugin": [
    ".opencode/plugins/tree-sitter-csharp.js",
    ".opencode/plugins/test-impact.js",
    ".opencode/plugins/git-smart-context.js",
    ".opencode/plugins/file-summary-cache.js"
  ],

  "autoupdate": false,

  "agent": {
    "build": {
      "description": "Primary autonomous build agent for large-scale software engineering tasks",
      "model": "omlx/Qwen3.6-35B-A3B-UD-MLX-4bit",
      "prompt": "You are a senior software architect responsible for building robust, scalable systems. Prioritize correctness, modular design, and performance.",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },

    "csharp-architect": {
      "description": "Senior C# architect for large enterprise-grade systems",
      "model": "omlx/Qwen3.6-35B-A3B-UD-MLX-4bit",
      "prompt": "You design large-scale .NET systems using clean architecture, SOLID principles, and high maintainability patterns. You optimize for AOT readiness and low allocations.",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },

    "csharp-performance": {
      "description": "Performance specialist for .NET systems",
      "model": "omlx/Qwen3.6-35B-A3B-UD-MLX-4bit",
      "prompt": "You optimize .NET systems for throughput, memory efficiency, and low GC pressure using spans, pooling, and allocation-free patterns.",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },

    "csharp-test-engineer": {
      "description": "Senior test engineer for .NET systems",
      "model": "omlx/Qwen3.6-35B-A3B-UD-MLX-4bit",
      "prompt": "You design deterministic, isolated, high-quality test suites for .NET systems with strong edge-case coverage.",
      "tools": {
        "write": true,
        "edit": true
      }
    },

    "code-reviewer": {
      "description": "Security and maintainability code reviewer",
      "model": "omlx/Qwen3.6-35B-A3B-UD-MLX-4bit",
      "prompt": "You review code strictly for security issues, performance regressions, and maintainability problems.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}