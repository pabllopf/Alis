{
  "securityPolicy": {
    "version": "1.0.0",
    "lastUpdated": "2026-06-09",
    "author": "Pablo Perdomo Falcón",
    "license": "GPLv3"
  },
  "securityLevels": {
    "public": {
      "description": "Open to all users",
      "encryption": "none",
      "accessControl": "none",
      "auditLogging": false
    },
    "internal": {
      "description": "Team members only",
      "encryption": "TLS 1.3",
      "accessControl": "role-based",
      "auditLogging": true
    },
    "private": {
      "description": "Restricted access",
      "encryption": "AES-256",
      "accessControl": "attribute-based",
      "auditLogging": true
    }
  },
  "securityFeatures": [
    "AOT compatibility (no System.Reflection.Emit)",
    "No external NuGet packages",
    "Cross-platform support (Windows, Linux, macOS, Web)",
    "Multi-targeted framework support (15+ frameworks)",
    "XML documentation for all public APIs",
    "Secure dependency management",
    "Code signing and verification"
  ],
  "securityChecks": {
    "dependencyScanning": true,
    "vulnerabilityAssessment": true,
    "codeAnalysis": true,
    "accessibilityTesting": true,
    "performanceTesting": true,
    "securityAudit": true
  },
  "compliance": {
    "standards": [
      "OWASP Top 10",
      "NIST Cybersecurity Framework",
      "ISO 27001",
      "GDPR"
    ],
    "certifications": []
  }
}
