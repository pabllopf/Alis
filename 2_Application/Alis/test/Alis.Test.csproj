        <NoWarn>$(NoWarn);NU1903</NoWarn> <!-- Error NU1903 : Warning As Error: Package has high severity vulnerability -->
        <NoWarn>$(NoWarn);NU1902</NoWarn> <!-- Error NU1902 : Warning As Error: Package has moderate severity vulnerabilities -->
        <NoWarn>$(NoWarn);CS0162</NoWarn>
        <NoWarn>$(NoWarn);NU5128</NoWarn> <!-- Error NU5128 : Warning As Error: The package contains a project reference -->
        <NoWarn>$(NoWarn);CS0067;CA1054;NU1904;MSB3245;CS1685;CA1815;CA2225;CA1051;CA2000;CA1062;CA1065;CA5392;CA1838;CA5392;A1834;CA2208;CA1725;CA1825;CA1044;CA2201;CA1024;CA1000;CA1813;CA1018;CA1032;CA1716;CA1040;CA1308;CA1721;CA1066;CA1866;CA1305;CA1310;CA1031;CA1034;CA1711;CA2249;CA1863;CA2007;CA1309;CA1822;CA1823;CA1824;CA1825;CA1826;CA1827;CA1828;CA1829;CA1830;CA1831;CA1832;CA1833;CA1834;CA1835;CA1836;CA1837;CA1838;CA1839;CA1840;CA1841;CA1842;CA1843;CA1844;CA1845;CA1846;CA1847;CA1848;CA1849;CA1850;CA1851;CA1852;CA1853;CA1854;CA1855;CA1856;CA1857;CA1858;CA1859;CA1860;CA1861;CA1862;CA1863;CA1864;CA1865;CA1866;CA1867;CA1868;CA1869;CA1870;CA1871;CA1872;CA1873;CA1874;CA1875;CA1876;CA1877;CA1878;CA1879;CA1880;CA1881;CA1882;CA1883;CA1884;CA1885;CA1886;CA1311;CA1304;CA1303;CA1307;CA2101;CA1806;CA1819;CA1008;CA1720;CA1805;CA1069;CA1028;CA1707;CA2227;CA1002;CA1003;CA2211;CA1012;CA1814;CA1063;CA1802;CA1507;CA1510;CA1030;CA1508;CA1033;CA1019;CA1052;CA2231;CA1810;CA1401;CA1512;CA1820;CA1708;CA2019;CA1710;CA2263;CA1724;CA2213;CA5398;CA2016;CA2213;CA5398;CA1712;CA1027;CA1700;CA2217;CA2237;CS1591;CA2020;ALIS009;ALIS010;ALIS001;NU1904;SYSLIB1054</NoWarn>
        <NoWarn>$(NoWarn);S4136</NoWarn> <!-- Warning S4136 : Method overloads should be grouped together -->
        <NoWarn>$(NoWarn);S4200</NoWarn> <!-- Warning S4200 : Native methods should be wrapped -->
        <NoWarn>$(NoWarn);S3925</NoWarn>  <!-- "ISerializable" should be implemented correctly -->
        <NoWarn>$(NoWarn);S3267</NoWarn> <!-- Warning S3267 : Loops should be simplified with "LINQ" expressions -->
        <NoWarn>$(NoWarn);CA1816;CA1816;CS0419;CS1572;CS1573;CS1574;CS1734;CS1572;CS1573;CS1574;CS0419;CS1734</NoWarn>
    </PropertyGroup>
    
    <ItemGroup>
        <ProjectReference Condition="$(ProjectDir.Contains('1_Presentation')) OR $(ProjectDir.Contains('2_Application'))"
                          Include="
          $(SolutionDir)3_Structuration/**/**/generator/**/Alis.*Generator.csproj;               
          $(SolutionDir)4_Operation/**/**/generator/**/Alis.*Generator.csproj;
          $(SolutionDir)5_Declaration/**/**/generator/**/Alis.*Generator.csproj;
          $(SolutionDir)6_Ideation/**/**/generator/**/Alis.*Generator.csproj;"
                          OutputItemType="Analyzer"
                          PrivateAssets="all"
                          ReferenceOutputAssembly="false">
            <Properties>
                TargetFramework=netstandard2.0
            </Properties>
        </ProjectReference>

        <ProjectReference Condition="$(ProjectDir.Contains('3_Structuration'))"
                          Include="          
          $(SolutionDir)4_Operation/**/**/generator/**/Alis.*Generator.csproj;
          $(SolutionDir)5_Declaration/**/**/generator/**/Alis.*Generator.csproj;
          $(SolutionDir)6_Ideation/**/**/generator/**/Alis.*Generator.csproj;"
                          OutputItemType="Analyzer"
                          PrivateAssets="all"
                          ReferenceOutputAssembly="false">
            <Properties>
                TargetFramework=netstandard2.0
            </Properties>
        </ProjectReference>

        <ProjectReference Condition="$(ProjectDir.Contains('4_Operation'))"
                          Include="          
          $(SolutionDir)5_Declaration/**/**/generator/**/Alis.*Generator.csproj;
          $(SolutionDir)6_Ideation/**/**/generator/**/Alis.*Generator.csproj;"
                          OutputItemType="Analyzer"
                          PrivateAssets="all"
                          ReferenceOutputAssembly="false">
            <Properties>
                TargetFramework=netstandard2.0
            </Properties>
        </ProjectReference>

        <ProjectReference Condition="$(ProjectDir.Contains('5_Declaration'))"
                          Include="          
          $(SolutionDir)6_Ideation/**/**/generator/**/Alis.*Generator.csproj;"
                          OutputItemType="Analyzer"
                          PrivateAssets="all"
                          ReferenceOutputAssembly="false">
            <Properties>
                TargetFramework=netstandard2.0
            </Properties>
        </ProjectReference>

    </ItemGroup>
    
    
    

     <ItemGroup>
        <AssemblyAttribute Condition="$(TargetFramework.Contains('net8'))" Include="System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute"/>
    </ItemGroup>

    <ItemGroup>
        <None Condition="Exists('$(ProjectDir).docs/')" Include="$(ProjectDir).docs/**/*.md" Pack="false" Visible="true"/>
    </ItemGroup>

    <ItemGroup Condition="
        $(AssemblyName.Contains('Graphic.Sdl2.Test')) == True OR
        $(AssemblyName.Contains('Graphic.Glfw.Test')) == True OR
        $(AssemblyName.Contains('Graphic.Sfml.Test')) == True OR
        $(AssemblyName.Contains('Graphic.Ui.Test')) == True OR
        $(AssemblyName.Contains('Graphic.Test')) == True OR
        $(AssemblyName.Contains('Audio.Test')) == True OR
        $(AssemblyName.Contains('Network.Test')) == True OR
        $(AssemblyName.Contains('FFmpeg.Test')) == True  OR
        $(AssemblyName.Contains('Ecs.Test')) == True 
    ">
        <Content Include="$(SolutionDir).config/xunit.runner.json" LinkBase="." Pack="true" Visible="true" PackagePath=".">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    

    <PropertyGroup Condition="($([MSBuild]::IsOSPlatform('linux')) AND '$(RuntimeIdentifier)' == '') OR $(RuntimeIdentifier.Contains('linux'))">
        <DefineConstants>$(DefineConstants);LINUX</DefineConstants>
        <IsLinux>true</IsLinux>
    </PropertyGroup>

    <PropertyGroup Condition="($([MSBuild]::IsOSPlatform('osx')) AND '$(RuntimeIdentifier)' == '')  OR $(RuntimeIdentifier.Contains('osx'))">
        <DefineConstants>$(DefineConstants);OSX</DefineConstants>
        <IsOSX>true</IsOSX>
    </PropertyGroup>

    <PropertyGroup Condition="($([MSBuild]::IsOSPlatform('windows')) AND '$(RuntimeIdentifier)' == '') OR $(RuntimeIdentifier.Contains('win'))">
        <DefineConstants>$(DefineConstants);WIN</DefineConstants>
        <IsWindows>true</IsWindows>
    </PropertyGroup>

    <PropertyGroup Condition="$(AssemblyName.Contains('Test'))">
        <NameTest>$([System.Text.RegularExpressions.Regex]::Replace('$(AssemblyName)', '.[^.]*Test[^*]*', ''))</NameTest>
    </PropertyGroup>

   <ItemGroup Condition="$(AssemblyName.Contains('Test')) AND $(NameTest.StartsWith('Alis'))">
        <ProjectReference
            Condition="Exists('$(ProjectDir)../src/$(NameTest).csproj') == True"
            Include="$(ProjectDir)../src/$(NameTest).csproj"/>

        <ProjectReference
            Condition="Exists('$(ProjectDir)../src/$(NameTest).csproj') == False"
            Include="$(ProjectDir)../../src/$(NameTest).csproj"/>

        <ProjectReference
            Condition="Exists('$(ProjectDir)../generator/$(NameTest).Generator.csproj')"
            Include="$(ProjectDir)../generator/$(NameTest).Generator.csproj"
            OutputItemType="Analyzer"
            PrivateAssets="all"
            ReferenceOutputAssembly="false">
            <Properties>
                TargetFramework=netstandard2.0
            </Properties>
        </ProjectReference>
    </ItemGroup>

           <!-- ========== PROPIEDADES DE ASSETS ========== -->
       <PropertyGroup>
           <!-- Carpeta de recursos -->
           <AssetsDir>$(ProjectDir)Assets</AssetsDir>
   
           <!-- Archivos generados intermedios -->
           <AssetsZip>$(ProjectDir)obj/assets.zip</AssetsZip>
           <AssetsOutput>$(ProjectDir)obj/assets.pack</AssetsOutput>
   
           <!-- Hash usado para detectar cambios reales de contenido -->
           <AssetHashAlgorithm Condition="'$(AssetHashAlgorithm)' == ''">SHA256</AssetHashAlgorithm>
       </PropertyGroup>
   
       <PropertyGroup Condition="'$(AssetsOutput)' != ''">
           <AssetsIntermediateDir Condition="'$(AssetsIntermediateDir)' == ''">$([System.IO.Path]::GetDirectoryName('$(AssetsOutput)'))</AssetsIntermediateDir>
           <AssetsManifest Condition="'$(AssetsManifest)' == ''">$(AssetsIntermediateDir)/assets.manifest</AssetsManifest>
       </PropertyGroup>
   
       <ItemGroup Condition="'$(AssetsDir)' != '' AND Exists('$(AssetsDir)')">
           <AssetPackInput Include="$(AssetsDir)/**/*" />
       </ItemGroup>
   
       <Target Name="_PrepareAssetPackManifest"
               Condition="'$(AssetsOutput)' != '' AND Exists('$(ProjectDir)')">
           <Message Importance="High"
                    Text="[Assets] _PrepareAssetPackManifest iniciado. AssetsDir='$(AssetsDir)' AssetsManifest='$(AssetsManifest)' Algoritmo='$(AssetHashAlgorithm)'" />
   
           <MakeDir Directories="$(AssetsIntermediateDir)" Condition="'$(AssetsIntermediateDir)' != ''" />
   
           <Message Importance="High"
                    Text="[Assets] Ficheros detectados: @(AssetPackInput->Count())"
                    Condition="Exists('$(AssetsDir)')" />
   
           <!-- Calcula hash por fichero y conserva metadatos (incluye FullPath) -->
           <GetFileHash Files="@(AssetPackInput)"
                        Algorithm="$(AssetHashAlgorithm)"
                        Condition="Exists('$(AssetsDir)')">
               <Output TaskParameter="Items" ItemName="AssetPackHashed" />
           </GetFileHash>
   
           <!-- Log por fichero: ruta completa + hash -->
           <Message Importance="Normal"
                    Text="[Assets] HASH %(AssetPackHashed.FullPath) | %(AssetPackHashed.FileHash)"
                    Condition="Exists('$(AssetsDir)')" />
   
           <!-- Manifiesto: FullPath|Hash -->
           <WriteLinesToFile File="$(AssetsManifest)"
                             Lines="@(AssetPackHashed->'%(FullPath)|%(FileHash)')"
                             Overwrite="true"
                             WriteOnlyWhenDifferent="true"
                             Encoding="ASCII"
                             Condition="Exists('$(AssetsDir)')" />
   
           <!-- Caso sin carpeta de assets -->
           <WriteLinesToFile File="$(AssetsManifest)"
                             Lines="__NO_ASSETS__"
                             Overwrite="true"
                             WriteOnlyWhenDifferent="true"
                             Encoding="ASCII"
                             Condition="!Exists('$(AssetsDir)')" />
   
           <Message Importance="High"
                    Text="[Assets] Manifiesto generado en '$(AssetsManifest)'."
                    Condition="Exists('$(AssetsDir)')" />
   
           <Message Importance="High"
                    Text="[Assets] No existe AssetsDir. Se escribe marcador __NO_ASSETS__ en el manifiesto."
                    Condition="!Exists('$(AssetsDir)')" />
       </Target>
   
       <Target Name="ZipAssets"
               DependsOnTargets="_PrepareAssetPackManifest"
               BeforeTargets="BeforeBuild;BeforePublish"
               Condition="'$(AssetsOutput)' != '' AND Exists('$(ProjectDir)')"
               Inputs="$(AssetsManifest)"
               Outputs="$(AssetsOutput)">
   
           <Message Text="[Assets] ZipAssets incremental: AssetsDir='$(AssetsDir)'; AssetsZip='$(AssetsZip)'; AssetsOutput='$(AssetsOutput)'; AssetsManifest='$(AssetsManifest)'"
                    Importance="High" />
   
           <MakeDir Directories="$(AssetsIntermediateDir)" Condition="'$(AssetsIntermediateDir)' != ''" />
   
           <Delete Files="$(AssetsZip)" Condition="Exists('$(AssetsZip)') AND Exists('$(AssetsDir)')" />
           <Message Importance="Normal"
                    Text="[Assets] ZIP previo eliminado: $(AssetsZip)"
                    Condition="Exists('$(AssetsDir)')" />
   
           <ZipDirectory SourceDirectory="$(AssetsDir)"
                         DestinationFile="$(AssetsZip)"
                         Condition="Exists('$(AssetsDir)')" />
           <Message Importance="High"
                    Text="[Assets] ZIP generado: $(AssetsZip)"
                    Condition="Exists('$(AssetsDir)')" />
   
           <Exec Condition="Exists('$(AssetsDir)') AND '$(OS)' == 'Windows_NT'"
                 Command="powershell -NoLogo -Command &quot;[Convert]::ToBase64String([System.IO.File]::ReadAllBytes('$(AssetsZip)')) | Out-File -FilePath '$(AssetsOutput)' -Encoding ASCII&quot;" />
           <Message Importance="High"
                    Text="[Assets] Base64 generado (Windows) en: $(AssetsOutput)"
                    Condition="Exists('$(AssetsDir)') AND '$(OS)' == 'Windows_NT'" />
   
           <Exec Condition="Exists('$(AssetsDir)') AND '$(OS)' != 'Windows_NT'"
                 Command="sh -c &quot;base64 &lt; '$(AssetsZip)' &gt; '$(AssetsOutput)'&quot;" />
           <Message Importance="High"
                    Text="[Assets] Base64 generado (Unix) en: $(AssetsOutput)"
                    Condition="Exists('$(AssetsDir)') AND '$(OS)' != 'Windows_NT'" />
   
           <WriteLinesToFile File="$(AssetsOutput)"
                             Lines=""
                             Overwrite="true"
                             WriteOnlyWhenDifferent="true"
                             Encoding="ASCII"
                             Condition="!Exists('$(AssetsDir)')" />
           <Message Importance="High"
                    Text="[Assets] Sin assets: se genera archivo vacío en $(AssetsOutput)"
                    Condition="!Exists('$(AssetsDir)')" />
       </Target>
   
       <!-- ========== REGISTRO DEL OUTPUT ========== -->
       <ItemGroup>
           <AdditionalFiles Include="$(AssetsOutput)"
                            CopyToOutputDirectory="Never"
                            CopyToPublishDirectory="Never"
                            Visible="false" />
       </ItemGroup>


</Project>