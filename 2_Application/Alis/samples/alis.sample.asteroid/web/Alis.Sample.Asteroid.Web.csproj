                using System%3b
                using System.Runtime.InteropServices%3b
                using System.Threading.Tasks%3b
                using Alis.Core.Ecs.Systems%3b
                using Alis.Core.Graphic.OpenGL%3b
                using Alis.Core.Graphic.Platforms.Web%3b
                
                namespace $(RootNamespace)
                {
                    /// &lt;summary&gt;
                    /// The entry point class
                    /// &lt;/summary&gt;
                    public static class EntryPoint
                    {
                        
                        /// &lt;summary&gt;
                        /// Gets or sets the value of the base address
                        /// &lt;/summary&gt;
                        public static Uri BaseAddress { get%3b internal set%3b }
                        
                        /// &lt;summary&gt;
                        /// Gets or sets the value of the game alis
                        /// &lt;/summary&gt;
                        private static VideoGame GameAlis { get%3b set%3b }
                        
                        /// &lt;summary&gt;
                        /// Frames the time
                        /// &lt;/summary&gt;
                        /// &lt;param name="time"&gt;The time&lt;/param&gt;
                        /// &lt;param name="userData"&gt;The user data&lt;/param&gt;
                        /// &lt;returns&gt;The int&lt;/returns&gt;
                        [UnmanagedCallersOnly]
                        public static int Frame(double time, nint userData)
                        {
                            GameAlis.Preview()%3b
                            return 1%3b
                        }
                        
                        /// &lt;summary&gt;
                        /// Gets or sets the value of the canvas width
                        /// &lt;/summary&gt;
                        private static int CanvasWidth { get%3b set%3b }
                
                        /// &lt;summary&gt;
                        /// Gets or sets the value of the canvas height
                        /// &lt;/summary&gt;
                        private static int CanvasHeight { get%3b set%3b }
                
                        /// &lt;summary&gt;
                        /// Canvases the resized using the specified width
                        /// &lt;/summary&gt;
                        /// &lt;param name="width"&gt;The width&lt;/param&gt;
                        /// &lt;param name="height"&gt;The height&lt;/param&gt;
                        public static void CanvasResized(int width, int height)
                        {
                             CanvasWidth = width%3b
                         CanvasHeight = height%3b
                     
                         if(GameAlis == null)
                         {
                             return%3b
                         }
                         
                         // Resolución original del juego
                         int gameWidth = (int)GameAlis.Context.Setting.Graphic.WindowSize.X%3b
                         int gameHeight = (int)GameAlis.Context.Setting.Graphic.WindowSize.Y%3b
                     
                         float aspectGame = (float)gameWidth / gameHeight%3b
                         float aspectCanvas = (float)width / height%3b
                     
                         int viewportWidth, viewportHeight, viewportX, viewportY%3b
                     
                         if (aspectCanvas > aspectGame)
                         {
                             // Canvas más ancho, barras laterales
                             viewportHeight = height%3b
                             viewportWidth = (int)(height * aspectGame)%3b
                             viewportX = (width - viewportWidth) / 2%3b
                             viewportY = 0%3b
                         }
                         else
                         {
                             // Canvas más alto, barras arriba y abajo
                             viewportWidth = width%3b
                             viewportHeight = (int)(width / aspectGame)%3b
                             viewportX = 0%3b
                             viewportY = (height - viewportHeight) / 2%3b
                         }
                     
                         Gl.GlViewport(viewportX, viewportY, viewportWidth, viewportHeight)%3b
                        }
                        
                        /// &lt;summary&gt;
                        /// Mains the args
                        /// &lt;/summary&gt;
                        /// &lt;param name="args"&gt;The args&lt;/param&gt;
                        /// &lt;exception cref="Exception"&gt;Display was null&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;Initialize() returned false.&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;ChoseConfig() failed&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;ChoseConfig() returned no configs&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;BindApi() failed&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;CreateContext() failed&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;CreateWindowSurface() failed&lt;/exception&gt;
                        /// &lt;exception cref="Exception"&gt;MakeCurrent() failed&lt;/exception&gt;
                        public async static Task Main(string[] args)
                        {
                            Console.WriteLine($"Hello from dotnet!")%3b
                
                            IntPtr display = EGL.GetDisplay(IntPtr.Zero)%3b
                            if (display == IntPtr.Zero)
                            {
                                throw new Exception("Display was null")%3b
                            }
                
                            if (!EGL.Initialize(display, out int major, out int minor))
                            {
                                throw new Exception("Initialize() returned false.")%3b
                            }
                
                            int[] attributeList = new int[]
                            {
                                EGL.EGL_RED_SIZE  , 8,
                                EGL.EGL_GREEN_SIZE, 8,
                                EGL.EGL_BLUE_SIZE , 8,
                                EGL.EGL_DEPTH_SIZE, 24,
                                EGL.EGL_STENCIL_SIZE, 8,
                                EGL.EGL_SURFACE_TYPE, EGL.EGL_WINDOW_BIT,
                                EGL.EGL_RENDERABLE_TYPE, EGL.EGL_OPENGL_ES3_BIT,
                                EGL.EGL_SAMPLES, 16, //MSAA, 16 samples
                                EGL.EGL_NONE
                            }%3b
                
                            IntPtr config = IntPtr.Zero%3b
                            IntPtr numConfig = IntPtr.Zero%3b
                            if (!EGL.ChooseConfig(display, attributeList, ref config, 1, ref numConfig))
                            {
                                throw new Exception("ChoseConfig() failed")%3b
                            }
                
                            if (numConfig == IntPtr.Zero)
                            {
                                throw new Exception("ChoseConfig() returned no configs")%3b
                            }
                
                            if (!EGL.BindApi(EGL.EGL_OPENGL_ES_API))
                            {
                                throw new Exception("BindApi() failed")%3b
                            }
                
                            int[] ctxAttribs = new int[] { EGL.EGL_CONTEXT_CLIENT_VERSION, 3, EGL.EGL_NONE }%3b
                            IntPtr context = EGL.CreateContext(display, config, EGL.EGL_NO_CONTEXT, ctxAttribs)%3b
                            if (context == IntPtr.Zero)
                            {
                                throw new Exception("CreateContext() failed")%3b
                            }
                            
                            IntPtr surface = EGL.CreateWindowSurface(display, config, IntPtr.Zero, IntPtr.Zero)%3b
                            if (surface == IntPtr.Zero)
                            {
                                throw new Exception("CreateWindowSurface() failed")%3b
                            }
                
                            if (!EGL.MakeCurrent(display, surface, surface, context))
                            {
                                throw new Exception("MakeCurrent() failed")%3b
                            }
                            
                            Gl.Initialize(EGL.GetProcAddress)%3b
                
                            Interop.Initialize()%3b
                            
                            GameAlis = Game.Create(args)%3b
                            
                            GameAlis.InitPreview()%3b
                            
                          
                            int gameWidth = (int)GameAlis.Context.Setting.Graphic.WindowSize.X%3b
                            int gameHeight = (int)GameAlis.Context.Setting.Graphic.WindowSize.Y%3b
                     
                            float aspectGame = (float)gameWidth / gameHeight%3b
                            float aspectCanvas = (float)CanvasWidth / CanvasHeight%3b
                     
                            int viewportWidth, viewportHeight, viewportX, viewportY%3b
                     
                            if (aspectCanvas > aspectGame)
                            {
                                // Canvas más ancho, barras laterales
                                viewportHeight = CanvasHeight%3b
                                viewportWidth = (int)(CanvasHeight * aspectGame)%3b
                                viewportX = (CanvasWidth - viewportWidth) / 2%3b
                                viewportY = 0%3b
                            }
                            else
                            {
                                // Canvas más alto, barras arriba y abajo
                                viewportWidth = CanvasWidth%3b
                                viewportHeight = (int)(CanvasWidth / aspectGame)%3b
                                viewportX = 0%3b
                                viewportY = (CanvasHeight - viewportHeight) / 2%3b
                            }
                     
                            Gl.GlViewport(viewportX, viewportY, viewportWidth, viewportHeight)%3b
                            
                            unsafe
                            {
                               Emscripten.RequestAnimationFrameLoop((IntPtr)(delegate* unmanaged&lt;double, nint, int&gt;)&amp;Frame, nint.Zero)%3b
                            }
                        }
                    }
                }
            '
            Overwrite="true" />


