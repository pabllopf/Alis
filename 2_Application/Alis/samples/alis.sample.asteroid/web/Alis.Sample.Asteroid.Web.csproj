<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>13</LangVersion>
        <OutputType>Exe</OutputType>
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <NoAutoGenerateFiles>false</NoAutoGenerateFiles>
        <WasmAllowUndefinedSymbols>true</WasmAllowUndefinedSymbols>
        <EmscriptenLinkingFlags>-sWASM_ASYNC_COMPILATION=0 -sALLOW_UNIMPLEMENTED_SYSCALLS=1</EmscriptenLinkingFlags>
    </PropertyGroup>

    <PropertyGroup>
        <IsBrowserWasm Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">true</IsBrowserWasm>
        <IsBrowserWasm Condition="'$(RuntimeIdentifier)' != 'browser-wasm'">false</IsBrowserWasm>
    </PropertyGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute"/>
    </ItemGroup>

    <ItemGroup>
        <None Condition="Exists('$(ProjectDir).docs/')" Include="$(ProjectDir).docs/**/*.md" Pack="false" Visible="true"/>
    </ItemGroup>


    <Target Name="GenerateGitattributesForBrowserWasm" BeforeTargets="CoreCompile" Condition="$(NoAutoGenerateFiles) != 'true'">
        <WriteLinesToFile
            Condition="'$(IsBrowserWasm)' == 'true'"
            File="$(MSBuildProjectDirectory)/.gitattributes"
            Lines="# put these in .gitattributes file
                *.js binary
                *.json binary
                *.css binary
                *.html binary"
            Overwrite="true" />

        <WriteLinesToFile
            Condition="'$(IsBrowserWasm)' == 'true'"
            File="$(MSBuildProjectDirectory)/.nojekyll"
            Lines=""
            Overwrite="true" />

        <WriteLinesToFile
            Condition="'$(IsBrowserWasm)' == 'true' AND !Exists('$(MSBuildProjectDirectory)/Native/emscripten.c')"
            File="$(MSBuildProjectDirectory)/Native/emscripten.c"
